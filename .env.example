# ─────────────────────────────────────────────────────────────────────────────
# Blis-Q environment variables. Copy to .env and fill in. NEVER commit real
# secrets. Redis is REQUIRED in production — the server refuses to start without
# it (rate limiting fails closed). R2 and the RevenueCat secret are likewise
# required in production (enforced in server/env.ts).
#
# User-facing copy is in Polish; these are configuration only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase, Frankfurt / eu-central-1) ─────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:6543/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key            # client-side Realtime Broadcast only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — never exposed

# ── Auth / tokens ──────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-at-least-32-characters-long

# ── Client (Expo build-time, EXPO_PUBLIC_*) ───────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:5000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Firebase (Google Sign-In + push relay) ────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=                       # server-side admin
FIREBASE_CLIENT_EMAIL=                     # server-side admin
FIREBASE_PRIVATE_KEY=                      # server-side admin (escaped \n newlines)

# ── Cloudflare R2 (EU jurisdiction bucket) — required in production ────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET_AVATARS=blis-q-avatars
R2_BUCKET_COMMUNITY_IMAGES=blis-q-community-images
R2_BUCKET_EVENT_IMAGES=blis-q-event-images
R2_BUCKET_POST_IMAGES=blis-q-post-images
R2_BUCKET_SAFE_PLACE_IMAGES=blis-q-safe-place-images
R2_BUCKET_NEWS_IMAGES=blis-q-news-images

# ── Upstash Redis (Frankfurt) — required in production ─────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Email (Resend) — verify a custom sender domain before launch ───────────────
RESEND_API_KEY=

# ── RevenueCat webhook — required in production ────────────────────────────────
REVENUECAT_WEBHOOK_SECRET=

# ── Sentry (EU data region) — required before launch ──────────────────────────
SENTRY_DSN=

# ── App URLs ───────────────────────────────────────────────────────────────────
INVITE_LINK_BASE=http://localhost:5000
WEB_APP_URL=http://localhost:8081
ADMIN_APP_URL=http://localhost:5173        # admin dashboard origin (CORS allowlist)
