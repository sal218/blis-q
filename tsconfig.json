{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["node", "jest"],
    "paths": {
      "@/*": ["./client/*"],
      "@shared/*": ["./shared/*"],
      "@assets/*": ["./assets/*"]
    }
  },
  "include": ["server", "shared", "client", "*.config.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", "admin", "dist", "static-build", ".expo"],
  "extends": "expo/tsconfig.base"
}
