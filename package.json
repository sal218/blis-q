{
  "name": "blis-q",
  "version": "0.1.0",
  "private": true,
  "description": "Blis-Q — community platform for Poland's LGBT+ community (Expo client + Express API).",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "all:dev": "concurrently -n expo,server -c cyan,magenta \"npm:expo:dev\" \"npm:server:dev\"",
    "expo:dev": "expo start",
    "server:dev": "tsx watch server/index.ts",
    "db:push": "drizzle-kit push --force",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit",
    "format": "prettier --write .",
    "expo:static:build": "expo export --platform web --output-dir static-build",
    "server:build": "esbuild server/index.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/index.js",
    "server:prod": "node dist/index.js",
    "test": "node --test --import tsx server/__tests__/env.unit.test.ts",
    "test:integration": "jest",
    "test:client": "jest --config jest.client.config.ts",
    "test:all": "npm run test && npm run test:integration && npm run test:client"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@react-native-google-signin/google-signin": "^13.3.1",
    "@react-navigation/bottom-tabs": "^7.18.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.17.2",
    "@supabase/supabase-js": "^2.45.0",
    "@upstash/ratelimit": "^2.0.3",
    "@upstash/redis": "^1.34.0",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "expo": "^54.0.0",
    "expo-constants": "~18.0.0",
    "expo-linking": "~8.0.8",
    "expo-notifications": "~0.32.0",
    "expo-secure-store": "~15.0.0",
    "express": "^4.21.0",
    "firebase-admin": "^12.5.0",
    "helmet": "^8.0.0",
    "jose": "^5.9.0",
    "pg": "^8.13.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-safe-area-context": "^5.0.0",
    "react-native-screens": "^4.0.0",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.0",
    "@types/pg": "^8.11.10",
    "@types/react": "~19.1.0",
    "@types/supertest": "^7.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "concurrently": "^9.0.1",
    "drizzle-kit": "^0.28.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.11.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "prettier": "^3.3.3",
    "react-test-renderer": "^19.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.1"
  }
}
